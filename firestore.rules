rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Fields:
    //   - items: list (required) - Array of order items
    //   - total: number (required) - Total price
    //   - status: string (required, enum) - ['pending', 'preparing', 'ready', 'completed', 'cancelled']
    //   - customerName: string (required, size < 100)
    //   - customerPhone: string (required, size < 20)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum) - ['admin', 'worker']
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "calebl012711@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isWorker() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'worker' ||
        isAdmin()
      );
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'status', 'customerName', 'customerPhone', 'createdAt']) &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.customerPhone is string && data.customerPhone.size() < 20 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /orders/{orderId} {
      // Public can create orders
      allow create: if isValidOrder(request.resource.data) && 
                      request.resource.data.status == 'pending' &&
                      request.resource.data.createdAt == request.time;
      
      // Only workers/admins can read and update orders
      allow read, update: if isWorker();
      
      // Only admins can delete orders
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
