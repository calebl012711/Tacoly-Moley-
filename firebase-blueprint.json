{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order for food",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "description": "List of items in the order"
        },
        "total": {
          "type": "number",
          "description": "Total price of the order"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "ready", "completed", "cancelled"],
          "description": "Current status of the order"
        },
        "customerName": {
          "type": "string",
          "description": "Name of the customer"
        },
        "customerPhone": {
          "type": "string",
          "description": "Phone number of the customer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was placed"
        }
      },
      "required": ["items", "total", "status", "customerName", "customerPhone", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system (admin or worker)",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "worker"],
          "description": "User's role in the system"
        }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of authorized users"
    }
  }
}
